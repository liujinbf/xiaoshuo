# ===== 服务端 AI 配置（可选，前端也可在页面内配置）=====

# OpenAI 兼容的 API Key（适用于 OpenAI / DeepSeek / Gemini 等）
OPENAI_API_KEY=sk-your-api-key

# AI_BASE_URL：API 基础地址（不同模型填不同地址）
# OpenAI:   https://api.openai.com
# DeepSeek: https://api.deepseek.com
# Gemini:   https://generativelanguage.googleapis.com/v1beta/openai
AI_BASE_URL=https://api.deepseek.com

# 模型名称（截至 2026年5月的最新可用版本）
# DeepSeek: deepseek-v4-flash（推荐）/ deepseek-v4-pro
#           注意：deepseek-chat 将于 2026-07-24 弃用
# OpenAI:   gpt-5.5 / gpt-5.4-mini
#           注意：gpt-4o / gpt-4.1 已进入 Legacy 状态
# Gemini:   gemini-2.5-pro / gemini-2.5-flash
# Claude:   claude-sonnet-4-6 / claude-haiku-4-5（需 OpenAI 兼容代理）
OPENAI_MODEL=deepseek-v4-flash

PORT=4173

# 生产或多人环境必须显式配置，建议使用 32 字节以上随机字符串。
JWT_SECRET=replace-with-a-long-random-secret
