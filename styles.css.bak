  gap: 8px;
}状态：客户端模型已配置 */
.api-status.client-ready {
  color: var(--gold);
  border-color: rgba(185, 130, 42, 0.42);
  background: rgba(185, 130, 42, 0.08);
}

/* ===== 字数目标进度条 ===== */
.draft-progress-wrap {
  height: 5px;
  margin-bottom: 10px;
  border-radius: 999px;
  background: var(--line);
  overflow: hidden;
}

.draft-progress-fill {
  height: 100%;
  width: 0%;
  border-radius: inherit;
  background: var(--gold);
  transition: width 400ms ease, background 400ms ease;
}

.draft-progress-fill.near { background: #4caf82; }
.draft-progress-fill.done { background: var(--green); }

/* 自动保存时间标记 */
.autosave-badge {
  color: rgba(99, 99, 92, 0.7);
  font-size: 11px;
  font-style: italic;
}

/* ===== Tab 切换 ===== */
.workspace-tabs {
  display: flex;
  gap: 4px;
  margin-bottom: 24px;
  padding: 4px;
  border-radius: 10px;
  background: rgba(25, 25, 25, 0.06);
  width: fit-content;
}

.tab-btn {
  min-height: 36px;
  padding: 0 18px;
  border: 0;
  border-radius: 7px;
  background: transparent;
  color: var(--muted);
  font-family: "Microsoft YaHei", sans-serif;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition: background 160ms, color 160ms;
}

.tab-btn.active {
  background: var(--white);
  color: var(--ink);
  box-shadow: 0 2px 8px rgba(25, 25, 25, 0.1);
}

/* ===== 连载布局 ===== */
.serial-layout {
  display: grid;
  grid-template-columns: 300px 1fr;
  gap: 20px;
  align-items: start;
  min-height: 600px;
}

.serial-sidebar {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.serial-create {
  padding: 18px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--white);
  display: grid;
  gap: 12px;
}

.serial-create h3 {
  font-size: 18px;
  margin-bottom: 0;
}

.serial-meta-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.serial-create-btn {
  width: 100%;
  min-height: 42px;
  color: var(--white);
  border: 0;
  border-radius: 7px;
  background: var(--red);
  font-family: "Microsoft YaHei", sans-serif;
  font-weight: 800;
  font-size: 14px;
  cursor: pointer;
  transition: opacity 160ms;
}

.serial-create-btn:disabled { opacity: 0.55; cursor: not-allowed; }

.serial-create textarea {
  min-height: 72px;
  resize: vertical;
}

/* 小说卡片列表 */
.serial-novel-list {
  display: grid;
  gap: 8px;
}

.serial-empty-hint {
  color: var(--muted);
  font-family: "Microsoft YaHei", sans-serif;
  font-size: 13px;
  text-align: center;
  padding: 16px 0;
}

.novel-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  padding: 12px 14px;
  border: 1px solid var(--line);
  border-radius: 7px;
  background: var(--white);
  cursor: pointer;
  transition: border-color 160ms, background 160ms;
}

.novel-card:hover { border-color: var(--ink); }
.novel-card.active { border-color: var(--red); background: rgba(200, 59, 40, 0.05); }

.novel-card-info {
  display: flex;
  flex-direction: column;
  gap: 3px;
  min-width: 0;
}

.novel-card-info strong {
  font-size: 14px;
  font-weight: 800;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.novel-card-info span {
  font-family: "Microsoft YaHei", sans-serif;
  font-size: 12px;
  color: var(--muted);
}

.novel-delete-btn {
  flex-shrink: 0;
  width: 28px;
  height: 28px;
  border: 1px solid var(--line);
  border-radius: 50%;
  background: transparent;
  color: var(--muted);
  font-size: 16px;
  line-height: 1;
  cursor: pointer;
  transition: background 160ms, color 160ms;
}

.novel-delete-btn:hover { background: var(--red); color: white; border-color: var(--red); }

/* ===== 连载主工作区 ===== */
.serial-main {
  position: relative;
  min-height: 500px;
}

.serial-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
  min-height: 400px;
  color: var(--muted);
  font-family: "Microsoft YaHei", sans-serif;
  text-align: center;
  line-height: 1.8;
}

.serial-empty-icon { font-size: 52px; }

.serial-workspace { display: grid; gap: 16px; }

.serial-ws-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--line);
}

.serial-ws-header h2 { font-size: clamp(22px, 3vw, 36px); }

.serial-ws-actions {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}

.serial-progress-badge {
  display: inline-flex;
  align-items: center;
  min-height: 32px;
  padding: 0 12px;
  border: 1px solid var(--line);
  border-radius: 999px;
  background: var(--white);
  font-family: "Microsoft YaHei", sans-serif;
  font-size: 12px;
  font-weight: 700;
  color: var(--muted);
}

.serial-gen-btn {
  min-height: 42px;
  padding: 0 20px;
  color: var(--white);
  border: 0;
  border-radius: 7px;
  background: linear-gradient(135deg, #c83b28, #9b2a1a);
  font-family: "Microsoft YaHei", sans-serif;
  font-weight: 800;
  font-size: 14px;
  cursor: pointer;
  box-shadow: 4px 4px 0 rgba(200, 59, 40, 0.22);
  transition: transform 160ms, box-shadow 160ms, opacity 160ms;
}

.serial-gen-btn:hover { transform: translateY(-1px); box-shadow: 6px 6px 0 rgba(200, 59, 40, 0.22); }
.serial-gen-btn:disabled { opacity: 0.55; cursor: not-allowed; transform: none; }

/* 最新记忆条 */
.serial-summary-bar {
  padding: 12px 16px;
  border-left: 4px solid var(--gold);
  border-radius: 0 6px 6px 0;
  background: rgba(185, 130, 42, 0.08);
  font-family: "Microsoft YaHei", sans-serif;
  font-size: 13px;
  line-height: 1.7;
  color: #4a4530;
}

/* 章节列表 */
.serial-chapter-list { display: grid; gap: 12px; }

.chapter-empty-hint {
  color: var(--muted);
  font-family: "Microsoft YaHei", sans-serif;
  font-size: 13px;
  text-align: center;
  padding: 32px 0;
}

.chapter-card {
  padding: 16px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--white);
  display: grid;
  gap: 8px;
}

.chapter-card-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.chapter-card-meta strong { font-size: 15px; font-weight: 800; }

.chapter-card-meta span {
  font-family: "Microsoft YaHei", sans-serif;
  font-size: 12px;
  color: var(--muted);
}

.chapter-card-summary {
  margin: 0;
  color: var(--muted);
  font-family: "Microsoft YaHei", sans-serif;
  font-size: 13px;
  line-height: 1.65;
  border-left: 3px solid var(--line);
  padding-left: 10px;
}

.chapter-read-btn {
  justify-self: start;
  min-height: 32px;
  padding: 0 14px;
  border: 1px solid var(--line);
  border-radius: 6px;
  background: var(--white);
  color: var(--ink);
  font-family: "Microsoft YaHei", sans-serif;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition: background 160ms;
}

.chapter-read-btn:hover { background: var(--ink); color: var(--white); }

/* ===== 章节阅读器 ===== */
.chapter-reader {
  position: fixed;
  inset: 0;
  z-index: 50;
  background: var(--paper);
  overflow-y: auto;
  padding: 0;
}

.chapter-reader-bar {
  position: sticky;
  top: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 32px;
  background: rgba(246, 245, 239, 0.92);
  backdrop-filter: blur(8px);
  border-bottom: 1px solid var(--line);
  font-family: "Microsoft YaHei", sans-serif;
  font-size: 14px;
  font-weight: 700;
}

#closeReaderBtn {
  min-height: 34px;
  padding: 0 16px;
  border: 1px solid var(--line);
  border-radius: 6px;
  background: var(--white);
  font-family: "Microsoft YaHei", sans-serif;
  font-weight: 700;
  cursor: pointer;
}

.chapter-reader-body {
  max-width: 680px;
  margin: 0 auto;
  padding: 40px 32px 80px;
}

.chapter-reader-body p {
  font-size: 17px;
  line-height: 2.1;
  margin-bottom: 1.4em;
  color: #2a2820;
}

.diff-viewer {
  width: 100%;
  height: 350px;
  background-color: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: 6px;
  padding: 1rem;
  overflow-y: auto;
  font-family: monospace;
  font-size: 14px;
  line-height: 1.6;
  white-space: pre-wrap;
}

.diff-viewer ins {
  background-color: rgba(34, 197, 94, 0.2);
  color: #166534;
  text-decoration: none;
}

.diff-viewer del {
  background-color: rgba(239, 68, 68, 0.2);
  color: #991b1b;
  text-decoration: line-through;
}

@media (prefers-color-scheme: dark) {
  .diff-viewer ins {
    color: #4ade80;
  }
  .diff-viewer del {
    color: #f87171;
  }
}

.editor-actions {
  display: flex;
  gap: 8px;
}
